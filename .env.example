# ============================================================================
# GesLimpia — variables de entorno
# Copia este fichero a .env y rellena los valores.
#   cp .env.example .env
# NUNCA subas tu .env real a git (ya está en .gitignore).
# ============================================================================

# ----------------------------------------------------------------------------
# 1) BASE DE DATOS (PostgreSQL)
# ----------------------------------------------------------------------------
# El proyecto usa PostgreSQL tanto en desarrollo como en producción.
#
# · DESARROLLO (elige UNA opción):
#     a) Postgres local con Docker (incluido docker-compose.yml):
#        DATABASE_URL="postgresql://geslimpia:geslimpia@localhost:5432/geslimpia?schema=public"
#     b) Una base de datos de Neon de desarrollo (rama "dev"):
#        DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
#
# · PRODUCCIÓN (Vercel Postgres / Neon / Supabase): pega la cadena que te den.
#   Suele requerir SSL: añade ?sslmode=require al final si no viene incluido.
DATABASE_URL="postgresql://geslimpia:geslimpia@localhost:5432/geslimpia?schema=public"

# ----------------------------------------------------------------------------
# 2) NEXTAUTH (autenticación)
# ----------------------------------------------------------------------------
# Genera un secreto largo y aleatorio con:  openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
# URL base de la app. En local: http://localhost:3000
# En producción: https://TU-DOMINIO (sin barra final).
NEXTAUTH_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# 2b) LOGIN CON GOOGLE (OAuth) — opcional
# ----------------------------------------------------------------------------
# Credenciales de un "OAuth 2.0 Client ID" de Google Cloud (tipo "Web application").
# Ver README → "Login con Google" para crearlas. Redirect URI autorizado:
#   · Local:      http://localhost:3000/api/auth/callback/google
#   · Producción: https://TU-DOMINIO/api/auth/callback/google
# Si dejas estas dos variables vacías, el botón "Continuar con Google" NO se muestra
# y la app sigue funcionando solo con email/contraseña.
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ----------------------------------------------------------------------------
# 2c) reCAPTCHA v3 (anti-spam en registro y login) — opcional
# ----------------------------------------------------------------------------
# Protege los formularios públicos (registro y login email/contraseña) contra bots.
# Crea las claves en https://www.google.com/recaptcha/admin (tipo "reCAPTCHA v3",
# añade tu dominio geslimpia.es y localhost). Te dan dos claves:
#   · Site key   (pública, va al frontend)  -> NEXT_PUBLIC_RECAPTCHA_SITE_KEY
#   · Secret key (privada, va al servidor)  -> RECAPTCHA_SECRET_KEY
# Si dejas estas dos variables vacías, la verificación se OMITE (modo desarrollo):
# los formularios siguen funcionando sin reCAPTCHA. En producción, con las claves
# presentes, se verifica de verdad (score >= 0.5).
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# ----------------------------------------------------------------------------
# 2d) GOOGLE ANALYTICS (GA4) — opcional
# ----------------------------------------------------------------------------
# ID de medición de GA4 (formato G-XXXXXXX). Si lo dejas vacío, GA no se carga.
# IMPORTANTE: GA es una cookie ANALÍTICA. El script SOLO se carga si el usuario
# acepta las cookies analíticas en el banner de consentimiento (geslimpia_cc).
NEXT_PUBLIC_GA_ID=""

# ----------------------------------------------------------------------------
# 3) STRIPE (suscripciones)
# ----------------------------------------------------------------------------
# Claves desde https://dashboard.stripe.com/apikeys
#   · Modo test  -> sk_test_... / pk_test_...
#   · Producción -> sk_live_... / pk_live_...
# Si dejas valores con "placeholder" o vacíos, el checkout funciona en MODO DEMO
# (activa la suscripción sin cobro). Útil para desarrollo sin configurar Stripe.
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"

# Secreto del webhook (lo da Stripe al crear el endpoint, o `stripe listen` en local).
# Endpoint: https://TU-DOMINIO/api/stripe/webhook
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# IDs de precio recurrentes mensuales (crea 2 productos en Stripe):
#   · Plan Básico   29,99 €/mes  -> STRIPE_PRICE_BASICO
#   · Plan Completo 69,00 €/mes  -> STRIPE_PRICE_COMPLETO
STRIPE_PRICE_BASICO="price_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_COMPLETO="price_xxxxxxxxxxxxxxxxxxxxxxxx"

# ----------------------------------------------------------------------------
# 4) URL PÚBLICA DE LA APP
# ----------------------------------------------------------------------------
# Se usa para los redirects de Stripe Checkout (success_url / cancel_url).
# En local: http://localhost:3000  ·  En producción: https://TU-DOMINIO
NEXT_PUBLIC_APP_URL="http://localhost:3000"
