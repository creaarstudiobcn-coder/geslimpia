# ----------------------------------------------------------------------------
# GesLimpia — variables de entorno
# Copia este fichero a .env y rellena los valores.
# ----------------------------------------------------------------------------

# Base de datos
# En desarrollo usamos SQLite (rápido de arrancar, no requiere servidor).
DATABASE_URL="file:./dev.db"
# En producción (Vercel) usa PostgreSQL, p.ej. Supabase / Neon / Vercel Postgres:
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/geslimpia?schema=public"

# NextAuth
# Genera un secreto con: openssl rand -base64 32
NEXTAUTH_SECRET="cambia-esto-por-un-secreto-largo-y-aleatorio"
NEXTAUTH_URL="http://localhost:3000"

# Stripe (modo test) — claves desde https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_WEBHOOK_SECRET="whsec_xxxxxxxxxxxxxxxxxxxxxxxx"

# IDs de precio de Stripe (crea dos productos/precios recurrentes mensuales en modo test)
# Plan Básico 29,99 €/mes  y  Plan Completo 69,00 €/mes
STRIPE_PRICE_BASICO="price_xxxxxxxxxxxxxxxxxxxxxxxx"
STRIPE_PRICE_COMPLETO="price_xxxxxxxxxxxxxxxxxxxxxxxx"

# URL base pública de la app (para los redirects de Stripe Checkout)
NEXT_PUBLIC_APP_URL="http://localhost:3000"
