// GesLimpia — esquema de datos
// Base de datos: PostgreSQL (mismo provider en desarrollo y producción).
//   - Desarrollo: Postgres local vía Docker (docker-compose.yml) o una URL de Neon
//     de desarrollo. Ver README → "Desarrollo local con Postgres".
//   - Producción: Vercel Postgres / Neon / Supabase. Migraciones con `prisma migrate deploy`.
//
// Decisión de diseño: los "enums" se modelan como String con un conjunto de valores
// documentado (no enums nativos de Postgres), porque el código de la app compara
// strings literales ("HOGAR", "ACTIVA", …) en muchos sitios. Las listas (servicios,
// zonas) se guardan como texto JSON (ver helpers parseList/stringifyList en
// src/lib/constants.ts). Ambas elecciones son válidas y portables en Postgres.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String? // null para cuentas que entran solo con Google (OAuth)
  role         String? // "HOGAR" | "LIMPIADORA" | "ADMIN" | null (null = aún no ha elegido rol)
  ciudad       String? // opcional: las cuentas de Google la eligen en /onboarding/rol
  active       Boolean  @default(true) // false = cuenta desactivada por el admin (no puede entrar ni aparece en listados)
  // Prueba del consentimiento (RGPD art. 7.1: hay que poder demostrarlo).
  // Guardamos cuándo se aceptó y QUÉ versión de los textos legales estaba
  // vigente. null = alta anterior a que se recogiera; no se rellena a posteriori.
  consentAt      DateTime?
  consentVersion String?
  createdAt    DateTime @default(now())

  cleanerProfile CleanerProfile?
  subscription   Subscription?

  bookingsAsHome    Booking[] @relation("HomeBookings")
  bookingsAsCleaner Booking[] @relation("CleanerBookings")

  messages Message[]

  reviewsWritten  Review[] @relation("ReviewAuthor")
  reviewsReceived Review[] @relation("ReviewCleaner")

  favorites Favorite[] @relation("FavoriteHome")
  favoredBy Favorite[] @relation("FavoriteCleaner")

  supportMessages SupportMessage[] @relation("SupportThread")
  adminLogs       AdminLog[]       @relation("AdminActor")
}

model CleanerProfile {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio           String   @default("")
  hourlyRate    Float    @default(12)
  services      String   @default("[]") // JSON string[]
  zones         String   @default("[]") // JSON string[]
  availability  String   @default("") // texto libre, p.ej. "L-V mañanas"
  photoUrl      String   @default("")
  disponibleHoy Boolean  @default(true)
  verified      Boolean  @default(false) // sello "verificada" otorgado por el admin
  ratingAvg     Float    @default(0)
  ratingCount   Int      @default(0)
  onboarded     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Subscription {
  id                   String    @id @default(cuid())
  userId               String    @unique
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                 String // "BASICO" | "COMPLETO"
  status               String    @default("PENDIENTE") // "PENDIENTE" | "ACTIVA" | "CANCELADA"
  // Cupo de contactos consumido en el periodo en curso. Es un espejo para
  // mostrar en paneles: el valor que manda lo calcula lib/suscripcion.ts.
  contactsUsed         Int       @default(0)
  stripeCustomerId     String?
  stripeSubscriptionId String?
  // Periodo de facturación en curso, tal cual lo reporta Stripe. El inicio
  // delimita qué contactos cuentan para el cupo de este mes.
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
}

model Booking {
  id            String   @id @default(cuid())
  homeUserId    String
  homeUser      User     @relation("HomeBookings", fields: [homeUserId], references: [id], onDelete: Cascade)
  cleanerUserId String
  cleanerUser   User     @relation("CleanerBookings", fields: [cleanerUserId], references: [id], onDelete: Cascade)
  date          DateTime
  hours         Float    @default(2)
  status        String   @default("PENDIENTE") // "PENDIENTE" | "ACEPTADA" | "RECHAZADA" | "COMPLETADA"
  notes         String   @default("")
  createdAt     DateTime @default(now())

  messages Message[]
  review   Review?

  // El cupo de contactos se calcula recorriendo las reservas del hogar por
  // fecha, así que este índice sostiene la ruta más caliente del producto.
  @@index([homeUserId, createdAt])
}

model Message {
  id        String   @id @default(cuid())
  bookingId String
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  senderId  String
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)
  body      String
  createdAt DateTime @default(now())
}

model Review {
  id            String   @id @default(cuid())
  // Reserva valorada. Es lo que limita las reseñas: una por servicio prestado.
  // Sin esto, un hogar podía crear reseñas en bucle y hundir la media de una
  // limpiadora. Es opcional solo porque las reseñas anteriores a este campo no
  // tienen reserva asociada; la API exige siempre una para las nuevas.
  bookingId     String?  @unique
  booking       Booking? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  cleanerUserId String
  cleanerUser   User     @relation("ReviewCleaner", fields: [cleanerUserId], references: [id], onDelete: Cascade)
  homeUserId    String
  homeUser      User     @relation("ReviewAuthor", fields: [homeUserId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String   @default("")
  hidden        Boolean  @default(false) // true = oculta por el admin (no se muestra a los hogares ni cuenta para la media)
  createdAt     DateTime @default(now())

  @@index([cleanerUserId, hidden])
}

model Favorite {
  id            String   @id @default(cuid())
  homeUserId    String
  homeUser      User     @relation("FavoriteHome", fields: [homeUserId], references: [id], onDelete: Cascade)
  cleanerUserId String
  cleanerUser   User     @relation("FavoriteCleaner", fields: [cleanerUserId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())

  @@unique([homeUserId, cleanerUserId])
}

// Chat de soporte entre el ADMIN y un usuario (hogar o limpiadora). Aislado del
// chat de reservas (model Message): el "hilo" es el conjunto de mensajes de un userId.
model SupportMessage {
  id        String   @id @default(cuid())
  userId    String // el usuario (no-admin) con quien conversa el admin
  user      User     @relation("SupportThread", fields: [userId], references: [id], onDelete: Cascade)
  fromAdmin Boolean // true = lo envió el admin; false = lo envió el usuario
  body      String
  readByUser  Boolean @default(false) // el usuario ya lo leyó (para mensajes del admin)
  readByAdmin Boolean @default(false) // el admin ya lo leyó (para mensajes del usuario)
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Registro de auditoría de acciones del admin (sobre todo las destructivas).
model AdminLog {
  id         String   @id @default(cuid())
  adminId    String
  admin      User     @relation("AdminActor", fields: [adminId], references: [id], onDelete: Cascade)
  action     String // "VERIFY" | "UNVERIFY" | "DEACTIVATE" | "REACTIVATE" | "DELETE_USER" | "HIDE_REVIEW" | "SHOW_REVIEW" | "DELETE_REVIEW"
  targetType String // "USER" | "CLEANER"
  targetId   String
  detail     String   @default("")
  createdAt  DateTime @default(now())

  @@index([createdAt])
}
